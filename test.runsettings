<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <CollectFrom>
            [EventosVivos_Api]**
          </CollectFrom>
          <ExcludeByFile>
            **/Program.cs,
            **/Models/**/*.cs,
            **/Migrations/**/*.cs,
            **/DTO/**/*.cs
          </ExcludeByFile>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
