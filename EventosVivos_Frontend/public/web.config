<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- Configuración para redirección de rutas de Angular SPA -->
    <rewrite>
      <rules>
        <rule name="Angular Routes" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
            <add input="{REQUEST_URI}" pattern="\.mjs$" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <httpProtocol>
      <customHeaders>
        <!-- Habilitar HSTS (HTTP Strict Transport Security) -->
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains; preload" />
        
        <!-- Prevenir clickjacking (no permitir cargar en iframes) -->
        <add name="X-Frame-Options" value="DENY" />
        
        <!-- Prevenir MIME sniffing -->
        <add name="X-Content-Type-Options" value="nosniff" />
        
        <!-- Habilitar filtro XSS en navegadores antiguos -->
        <add name="X-XSS-Protection" value="1; mode=block" />
        
        <!-- Controlar la información del referrer -->
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        
        <!-- Política de permisos para desactivar funciones de hardware del dispositivo -->
        <add name="Permissions-Policy" value="camera=(), microphone=(), geolocation=(), payment=()" />
        
        <!-- Política de Seguridad de Contenido (CSP) con mejores prácticas -->
        <!-- 
          - default-src 'self': Permite cargar recursos únicamente del propio origen de la aplicación.
          - script-src 'self': Permite ejecutar scripts únicamente del propio origen.
          - style-src 'self' 'unsafe-inline' https://fonts.googleapis.com: Permite estilos locales, estilos en línea (requeridos por la inyección dinámica de componentes de Angular) y hojas de estilo de Google Fonts.
          - font-src 'self' data: https://fonts.gstatic.com https://fonts.googleapis.com: Permite cargar fuentes locales, en formato base64 inline y de los CDN de Google Fonts.
          - img-src 'self' data: https:: Permite cargar imágenes locales, en formato inline y de fuentes HTTPS externas.
          - connect-src 'self' http://localhost:5234 https://localhost:7110: Permite conexiones AJAX/Fetch del mismo origen y de la API local del Backend.
          - frame-ancestors 'none': Bloquea que el sitio sea embebido en iframes de terceros (medida contra clickjacking).
          - upgrade-insecure-requests: Instruye a los navegadores a actualizar automáticamente todas las solicitudes HTTP a HTTPS.
        -->
        <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com https://fonts.googleapis.com; img-src 'self' data: https:; connect-src 'self' http://localhost:5234 https://localhost:7110; frame-ancestors 'none'; upgrade-insecure-requests;" />
      </customHeaders>
    </httpProtocol>

    <staticContent>
      <!-- Configuración correcta de tipos MIME para fuentes y archivos JSON -->
      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff" mimeType="application/font-woff" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".ico" />
      <mimeMap fileExtension=".ico" mimeType="image/x-icon" />
      <remove fileExtension=".webp" />
    <mimeMap fileExtension=".webp" mimeType="image/webp" />
    </staticContent>
  </system.webServer>
</configuration>
